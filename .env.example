# === ClipSphere Phase 4 compose-level env ===
# Copy to .env and fill in real values. Never commit .env.

COMPOSE_PROJECT_NAME=clipsphere

# MongoDB
MONGO_INITDB_DATABASE=clipsphere

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadminchange
MINIO_BUCKET_VIDEOS=clipsphere-videos
MINIO_BUCKET_AVATARS=clipsphere-avatars

# Browser-reachable origin for presigned URLs. Nginx routes the bucket-path
# prefixes /clipsphere-videos/ and /clipsphere-avatars/ straight through to
# MinIO without rewrite, so the SigV4 canonical path matches.
MINIO_PUBLIC_URL=https://clipsphere.local

# Backend
JWT_SECRET=please_change_me_to_something_long_and_random
CLIENT_URL=https://clipsphere.local
CORS_ORIGINS=https://clipsphere.local

# Frontend
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_SOCKET_URL=https://clipsphere.local

# SMTP (leave SMTP_USER/SMTP_PASS empty in dev for Ethereal auto-account)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ClipSphere <noreply@clipsphere.local>

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=
