# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/clipsphere
JWT_SECRET=change_me_in_local_env
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5000
CLIENT_URL=http://localhost:3000

# ── MinIO / S3 ────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_VIDEOS=clipsphere-videos
MINIO_BUCKET_AVATARS=clipsphere-avatars
MINIO_USE_SSL=false

# ── SMTP / Email (Nodemailer) ─────────────────────────────────────────────
# Leave SMTP_USER/SMTP_PASS empty in dev to auto-create an Ethereal test account.
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ClipSphere <noreply@clipsphere.local>

# ── Stripe ────────────────────────────────────────────────────────────────
# Required for /api/v1/tips endpoints. In dev you can use a placeholder
# (e.g. sk_test_placeholder) — Stripe code paths only run when those routes
# are hit. The app will boot without a real key.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=