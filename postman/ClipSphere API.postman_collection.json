    {
      "name": "Register - Success",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const ts = Date.now();",
              "pm.environment.set('testEmail', 'user_' + ts + '@test.com');",
              "pm.environment.set('testUsername', 'user_' + ts);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has success status', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  pm.expect(responseBodyJson.status).to.equal('success');",
              "});",
              "",
              "pm.test('Response contains token', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  pm.expect(responseBodyJson.data.token).to.be.a('string');",
              "});",
              "",
              "pm.test('Response contains user object with required fields', function () {",
              "  const responseBodyJson = pm.response.json();",
              "  pm.expect(responseBodyJson.data.user).to.have.property('id');",
              "  pm.expect(responseBodyJson.data.user).to.have.property('username');",
              "  pm.expect(responseBodyJson.data.user).to.have.property('email');",
              "  pm.expect(responseBodyJson.data.user).to.have.property('role');",
              "});"
            ]
          }
        }
      ],
